# Root .env for docker-compose.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change-me-strong-root-password
DB_NAME=ecom
DB_USER=sani
DB_PASSWORD=change-me-strong-user-password

# --- Backend secrets ---
# Generate each: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string

# Set to "false" when serving HTTP (no TLS). Flip back to "true" once HTTPS is in place.
# When unset, defaults to true if NODE_ENV=production, false otherwise.
COOKIE_SECURE=true

# --- Host port for the public reverse proxy ---
# 8080 locally (so it doesn't need root). On the VPS set to 80.
HTTP_HOST_PORT=8080

# --- URLs ---
# FRONTEND_URL: used for CORS allow-list and email confirmation links.
#   Local: http://localhost:8080. Prod: http://your-ip-or-domain (matches HTTP_HOST_PORT).
# VITE_API_URL: baked into the frontend bundle at build time. Use the relative path /api
#   so the browser stays on the same origin (the reverse proxy strips /api/ before
#   forwarding to backend).
FRONTEND_URL=http://localhost:8080
VITE_API_URL=/api

# --- SMTP (registration emails + contact form) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
