# Root .env for docker-compose.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change-me-strong-root-password
DB_NAME=ecom
DB_USER=sani
DB_PASSWORD=change-me-strong-user-password

# --- Backend secrets ---
# Generate each: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string

# --- Host port mapping ---
# Defaults: 8080 (frontend) + 3000 (backend) for local dev.
# Production on the VPS: FRONTEND_HOST_PORT=80, BACKEND_HOST_PORT=3000 (until reverse proxy is added).
FRONTEND_HOST_PORT=8080
BACKEND_HOST_PORT=3000

# --- URLs ---
# Browser-facing URLs. In local dev: localhost. In prod: server IP (or domain once DNS is set).
FRONTEND_URL=http://localhost:8080
VITE_API_URL=http://localhost:3000

# --- SMTP (registration emails + contact form) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
