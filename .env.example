# Root .env for docker-compose.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change-me-strong-root-password
DB_NAME=ecom
DB_USER=sani
DB_PASSWORD=change-me-strong-user-password

# --- Backend secrets ---
# Generate each: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string

# --- URLs ---
# Local Docker: frontend on :8080 (browser), backend on :3000 (browser).
# Production: both behind the reverse proxy on the real domain - update accordingly.
FRONTEND_URL=http://localhost:8080
VITE_API_URL=http://localhost:3000

# --- SMTP (registration emails + contact form) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
