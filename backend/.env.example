# Backend environment variables.
# Copy to `.env` for local non-Docker development (`npm run start:dev`).
# For Docker / production, root-level `.env` next to docker-compose.yml is used instead.

# --- Database (MySQL) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=sani
DB_PASSWORD=sani123
DB_NAME=ecom

# --- JWT secrets ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string

# --- CORS allow-list (comma-separated) + base URL for email confirmation links ---
FRONTEND_URL=http://localhost:5173

# --- SMTP (required for registration emails and contact form) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
